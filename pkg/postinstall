#!/bin/sh
# postinstall - Set up spm after package installation

BASEDIR=${BASEDIR:-/opt/sst}

echo "Setting up spm..."

# Create runtime directories
mkdir -p ${BASEDIR}/var/cache 2>/dev/null
mkdir -p ${BASEDIR}/var/index 2>/dev/null
mkdir -p ${BASEDIR}/var/rollback 2>/dev/null

# Create symlinks in /usr/local/bin if it exists
if [ -d /usr/local/bin ]; then
    ln -sf ${BASEDIR}/bin/spm /usr/local/bin/spm 2>/dev/null
    ln -sf ${BASEDIR}/bin/spm-gui /usr/local/bin/spm-gui 2>/dev/null
    ln -sf ${BASEDIR}/bin/spm-agent /usr/local/bin/spm-agent 2>/dev/null
fi

# Install init.d script and rc links for agent boot start
if [ -f ${BASEDIR}/../etc/init.d/spm-agent ]; then
    cp ${BASEDIR}/../etc/init.d/spm-agent /etc/init.d/spm-agent 2>/dev/null
fi
if [ -x /etc/init.d/spm-agent ]; then
    ln -sf /etc/init.d/spm-agent /etc/rc2.d/S99spm-agent 2>/dev/null
    ln -sf /etc/init.d/spm-agent /etc/rc0.d/K01spm-agent 2>/dev/null
    echo "Starting spm update agent..."
    /etc/init.d/spm-agent start
fi

# Generate default config if not present
if [ ! -f ${BASEDIR}/etc/repos.conf ]; then
    cat > ${BASEDIR}/etc/repos.conf <<CONFEOF
# spm repository configuration
[ssl]
ca_bundle = /opt/sst/etc/ssl/certs/ca-bundle.crt

[agent]
interval = 21600
notify = yes

[repo:tgcware]
type = tgcware
name = TGCware Solaris 7 SPARC
url = https://jupiterrise.com/tgcware/sunos5.7_sparc/stable/
source = https://github.com/AstroVPK/tgcwarev2-for-solaris
enabled = yes

[repo:firefly128]
type = github
name = firefly128 SPARC Apps
owner = firefly128
repos = pizzafool,sparccord,wesnoth-sparc
enabled = yes

[repo:sunstorm]
type = github
name = Sunstorm Distribution
owner = firefly128
repos = sunstorm
enabled = yes
CONFEOF
fi

echo ""
echo "spm installed successfully."
echo ""
echo "Add to your PATH:"
echo "  PATH=${BASEDIR}/bin:\$PATH; export PATH"
echo ""
echo "CLI:   spm update"
echo "GUI:   spm-gui  (or use Application Manager)"
echo "Agent: /etc/init.d/spm-agent status"

# Reload CDE actions so Sunstorm Package Manager appears in Application Manager
if [ -x /usr/dt/bin/dtaction ]; then
    # Register in System_Admin drawer
    APPDIR=/usr/dt/appconfig/appmanager/C/System_Admin
    mkdir -p "${APPDIR}" 2>/dev/null
    ln -sf /usr/dt/appconfig/types/C/spm.dt "${APPDIR}/SpmGui" 2>/dev/null
    /usr/dt/bin/dtaction ReloadActions 2>/dev/null
    echo ""
    echo "CDE desktop integration installed."
    echo "Look for 'Sunstorm Package Manager' in Application Manager > System_Admin."
fi

exit 0
