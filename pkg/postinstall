#!/bin/sh
# postinstall - Set up solpkg after package installation

BASEDIR=${BASEDIR:-/opt/solpkg}

echo "Setting up solpkg..."

# Create runtime directories
mkdir -p ${BASEDIR}/var/cache 2>/dev/null
mkdir -p ${BASEDIR}/var/index 2>/dev/null
mkdir -p ${BASEDIR}/var/rollback 2>/dev/null

# Create symlinks in /usr/local/bin if it exists
if [ -d /usr/local/bin ]; then
    ln -sf ${BASEDIR}/bin/solpkg /usr/local/bin/solpkg 2>/dev/null
    ln -sf ${BASEDIR}/bin/solpkg-gui /usr/local/bin/solpkg-gui 2>/dev/null
    ln -sf ${BASEDIR}/bin/solpkg-agent /usr/local/bin/solpkg-agent 2>/dev/null
fi

# Install init.d script and rc links for agent boot start
if [ -f ${BASEDIR}/../etc/init.d/solpkg-agent ]; then
    cp ${BASEDIR}/../etc/init.d/solpkg-agent /etc/init.d/solpkg-agent 2>/dev/null
fi
if [ -x /etc/init.d/solpkg-agent ]; then
    ln -sf /etc/init.d/solpkg-agent /etc/rc2.d/S99solpkg-agent 2>/dev/null
    ln -sf /etc/init.d/solpkg-agent /etc/rc0.d/K01solpkg-agent 2>/dev/null
    echo "Starting solpkg update agent..."
    /etc/init.d/solpkg-agent start
fi

# Generate default config if not present
if [ ! -f ${BASEDIR}/etc/repos.conf ]; then
    cat > ${BASEDIR}/etc/repos.conf <<CONFEOF
# solpkg repository configuration
[ssl]
ca_bundle = /usr/tgcware/etc/curl-ca-bundle.pem

[agent]
interval = 21600
notify = yes

[repo:tgcware]
type = tgcware
name = TGCware Solaris 7 SPARC
url = https://jupiterrise.com/tgcware/sunos5.7_sparc/stable/
source = https://github.com/AstroVPK/tgcwarev2-for-solaris
enabled = yes

[repo:firefly128]
type = github
name = firefly128 SPARC Apps
owner = firefly128
repos = pizzafool,sparccord,wesnoth-sparc
enabled = yes
CONFEOF
fi

echo ""
echo "solpkg installed successfully."
echo ""
echo "Add to your PATH:"
echo "  PATH=${BASEDIR}/bin:\$PATH; export PATH"
echo ""
echo "CLI:   solpkg update"
echo "GUI:   solpkg-gui"
echo "Agent: /etc/init.d/solpkg-agent status"

exit 0
