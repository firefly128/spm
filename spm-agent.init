#!/bin/sh
#
# spm-agent - Solaris init.d script for the spm update agent
#
# Install:
#   cp spm-agent.init /etc/init.d/spm-agent
#   chmod 755 /etc/init.d/spm-agent
#   ln -s /etc/init.d/spm-agent /etc/rc2.d/S99spm-agent
#   ln -s /etc/init.d/spm-agent /etc/rc0.d/K01spm-agent
#

AGENT=/opt/sst/bin/spm-agent
PIDFILE=/opt/sst/var/agent.pid
LOGFILE=/opt/sst/var/agent.log

case "$1" in
start)
    if [ ! -x "$AGENT" ]; then
        echo "spm-agent: $AGENT not found"
        exit 1
    fi

    if [ -f "$PIDFILE" ]; then
        PID=`cat "$PIDFILE"`
        if kill -0 "$PID" 2>/dev/null; then
            echo "spm-agent already running (pid $PID)"
            exit 0
        fi
        # Stale PID file
        rm -f "$PIDFILE"
    fi

    echo "Starting spm-agent..."
    $AGENT
    ;;

stop)
    if [ -f "$PIDFILE" ]; then
        PID=`cat "$PIDFILE"`
        if kill -0 "$PID" 2>/dev/null; then
            echo "Stopping spm-agent (pid $PID)..."
            kill "$PID"
            # Wait up to 5 seconds
            i=0
            while [ $i -lt 10 ]; do
                if ! kill -0 "$PID" 2>/dev/null; then
                    break
                fi
                sleep 1
                i=`expr $i + 1`
            done
            if kill -0 "$PID" 2>/dev/null; then
                echo "Force killing spm-agent..."
                kill -9 "$PID"
            fi
        fi
        rm -f "$PIDFILE"
    else
        echo "spm-agent not running"
    fi
    ;;

restart)
    $0 stop
    sleep 1
    $0 start
    ;;

status)
    if [ -f "$PIDFILE" ]; then
        PID=`cat "$PIDFILE"`
        if kill -0 "$PID" 2>/dev/null; then
            echo "spm-agent is running (pid $PID)"

            # Show status file if available
            STATUS=/opt/sst/var/update.status
            if [ -f "$STATUS" ]; then
                echo "Last check:"
                cat "$STATUS"
            fi
            exit 0
        else
            echo "spm-agent not running (stale PID file)"
            exit 1
        fi
    else
        echo "spm-agent not running"
        exit 1
    fi
    ;;

reload)
    if [ -f "$PIDFILE" ]; then
        PID=`cat "$PIDFILE"`
        if kill -0 "$PID" 2>/dev/null; then
            echo "Reloading spm-agent config..."
            kill -HUP "$PID"
            exit 0
        fi
    fi
    echo "spm-agent not running"
    exit 1
    ;;

*)
    echo "Usage: $0 {start|stop|restart|status|reload}"
    exit 1
    ;;
esac

exit 0
